# split_wav_into_5s_segments.py
# Splits a WAV file into 5-second segments named _01, _02, ...
import wave
from pathlib import Path

input_path = Path(r"C:\Users\tim_e\Desktop\pilot\pilot_exp\resources\other_stimuli\blackbird_bbc.wav")
output_dir = Path(r"C:\Users\tim_e\Desktop\pilot\pilot_exp\loudspeaker_stimuli\environment")
segment_seconds = 5

output_dir.mkdir(parents=True, exist_ok=True)

with wave.open(str(input_path), "rb") as wf:
    nchannels = wf.getnchannels()
    sampwidth = wf.getsampwidth()
    framerate = wf.getframerate()
    nframes = wf.getnframes()
    params = wf.getparams()

    frames_per_segment = framerate * segment_seconds

    base = input_path.stem
    idx = 1
    while True:
        frames = wf.readframes(frames_per_segment)
        if not frames:
            break
        out_name = f"{base}_{idx:02d}.wav"
        out_path = output_dir / out_name
        with wave.open(str(out_path), "wb") as outw:
            outw.setnchannels(nchannels)
            outw.setsampwidth(sampwidth)
            outw.setframerate(framerate)
            outw.writeframes(frames)
        print(f"Saved: {out_path}")
        idx += 1

print(f"\nDone! Split {input_path.name} into {idx-1} segments in {output_dir}")